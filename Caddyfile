# HTTPS خودکار با گواهیِ واقعیِ Let's Encrypt.
# هاست از sslip.io ساخته شده که به IP سرور اشاره می‌کند (بدون نیاز به خریدِ دامنه).
# اگر بعداً دامنه‌ی واقعی گرفتی، فقط این خط را با دامنه‌ات عوض کن.
141.11.187.126.sslip.io {
	# تمام درخواست‌ها به سرویسِ api داخلِ شبکه‌ی داکر پراکسی می‌شوند.
	reverse_proxy api:8000
}
