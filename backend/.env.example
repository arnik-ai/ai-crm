# ===== Application =====
APP_ENV=development
APP_NAME=ai-crm
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://crm:crm@localhost:5432/crm

# ===== Redis / Celery =====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== JWT =====
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ===== Object Storage (S3-compatible) =====
S3_ENDPOINT=https://s3.example.ir
S3_BUCKET=crm-recordings
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ===== Telephony — workano یا simotel =====
TELEPHONY_PROVIDER=simotel

# Workano
WORKANO_WEBHOOK_SECRET=
WORKANO_API_BASE=https://pbx.workano.cloud/api
WORKANO_API_KEY=
WORKANO_IP_ALLOWLIST=

# Simotel
SIMOTEL_WEBHOOK_TOKEN=
SIMOTEL_WEBHOOK_SECRET=
SIMOTEL_API_BASE=
SIMOTEL_API_TOKEN=

# ===== AI (AvalAI) =====
AI_PROVIDER=avalai
AVALAI_API_KEY=
AVALAI_BASE_URL=https://api.avalai.ir/v1
AVALAI_LLM_MODEL=gpt-5.5
AVALAI_STT_MODEL=whisper-1
AI_LLM_TIMEOUT=60
AI_STT_TIMEOUT=120

# ===== Rate Limiting =====
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute

# ===== SMS / OTP (ورود با پیامک) =====
# console = حالت تست (کد در پاسخ API و لاگ برمی‌گردد، بدون ارسال واقعی)
# melipayamak = ارسال واقعی پیامک
SMS_PROVIDER=console
MELIPAYAMAK_USERNAME=
MELIPAYAMAK_PASSWORD=
MELIPAYAMAK_FROM=
MELIPAYAMAK_OTP_PATTERN=
OTP_LENGTH=5
OTP_TTL=120
OTP_REQUEST_COOLDOWN=60
OTP_MAX_ATTEMPTS=5
